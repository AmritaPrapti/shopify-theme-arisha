
{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
    <div class="banner-wrapper">
        <div class="hbanner-content page-width">
            {% if section.settings.subheading != blank %}
                <p class="hbanner-subheading">{{ section.settings.subheading }}</p>
            {% endif %}

            {% if section.settings.heading != blank %}
                <h2 class="hbanner-heading">{{ section.settings.heading }}</h2>
            {% endif %}

            {% if section.settings.details != blank %}
                <p class="hbanner-details">{{ section.settings.details }}</p>
            {% endif %}

            <div class="hbanner-buttons">
                {% if section.settings.link_1 != blank and section.settings.button_label_1 != blank %}
                    <a href="{{ section.settings.link_1 }}" class="button button--primary">{{ section.settings.button_label_1 }}</a>
                {% endif %}

                {% if section.settings.link_2 != blank and section.settings.button_label_2 != blank %}
                    <a href="{{ section.settings.link_2 }}" class="button button--secondary">{{ section.settings.button_label_2 }}</a>
                {% endif %}
            </div>
        </div>
        <div class="hbanner-image">
            {% render 'image', image: section.settings.image %}
        </div>
    </div>
</section>

{% schema %}
    {
        "name": "Hero Image Banner",
        "settings": [

            {
                "type": "image_picker",
                "id": "image",
                "label": "Hero Image"
            },
            {
                "type": "text",
                "id": "subheading",
                "label": "Subheading"
            },
            {
                "type": "textarea",
                "id": "heading",
                "label": "Heading",
                "info": " Use span tags to wrap the text you want to highlight. Example: <span>Highlight this text</span>"

            },
            {
                "type": "textarea",
                "id": "details",
                "label": "Details Text"
            },
            {
                "type": "url",
                "id": "link_1",
                "label": "Button Link"
            },
            {
                "type": "text",
                "id": "button_label_1",
                "label": "Button Label 1",
                "default": "Shop Starter Bundle"
            },
               {
                "type": "url",
                "id": "link_2",
                "label": "Button 2 Link"
            },
            {
                "type": "text",
                "id": "button_label_2",
                "label": "Button 2 Label",
                "default": "Shop All Products"
            },
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "t:sections.all.colors.label",
                "info": "t:sections.all.colors.has_cards_info",
                "default": "scheme-1"
            },    
            {
                "type": "header",
                "content": "t:sections.all.padding.section_padding_heading"
            },
            {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 36
            },
            {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_bottom",
            "default": 36
            }

        ],
        "presets": [
            {
                "name": "Hero Image Banner",
                "category": "Image"
            }
        ]
    }
{% endschema %}