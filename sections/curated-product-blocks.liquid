{{ 'curated-blocks.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div
  class="color-{{ section.settings.color_scheme }} isolate gradient"
>
  <div class="section-{{ section.id }}-padding page-width">
    <div class="curated-product-blocks grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down">
        {% for block in section.blocks %}
            {% assign product = block.settings.product %}
            {% assign product_form_id = 'quick-add-' | append: section.id | append: product.id %}
            {% if product %}
                <div class="curated-product-block {% if block.settings.make_it_selected %}selected{% endif %} grid__item color-{{ block.settings.color_scheme }} card">
                    <div class="curated-header" style="--badge-bg: {{ block.settings.bg_color }}; --badge-text: {{ block.settings.color_text }}">
                        <h2 class="curated-heading">{{ block.settings.heading }}</h2>
                        {% if block.settings.badge != blank %}
                            <span class="curated-badge">{{ block.settings.badge }}</span>
                        {% endif %}
                    </div>
                    <p class="curated-subheading">{{ block.settings.subheading }}</p>
                    <p class="description_heading">{{ block.settings.des_heading_1 }}</p>
                    <div class="curated-description">{{ block.settings.description_1 }}</div>
                    <p class="description_heading description_heading-2">{{ block.settings.des_heading_2 }}</p>
                    <button class="include-button des_toggle_btn" aria-expanded="false" aria-controls="description-{{ block.id }}" data-default-label="{{ block.settings.include_button_label }}">
                       <span class="button-label">{{ block.settings.include_button_label }} </span> 
                        <span class="svg-wrapper">
                            {{- 'icon-caret.svg' | inline_asset_content -}}
                        </span>
                    </button>
                    
                    <div class="curated-description des_toggle_content" id="description-{{ block.id }}">{{ block.settings.description_2 }}</div>
                    <div class="curated-price">
                        {% render 'price', product: product, show_sale_amount: true %}
                    </div>
                    <product-form data-section-id="{{ section.id }}">
                        {%- form 'product',
                            product,
                            id: product_form_id,
                            class: 'form',
                            novalidate: 'novalidate',
                            data-type: 'add-to-cart-form'
                            -%}
                            <input
                                type="hidden"
                                name="id"
                                value="{{ product.selected_or_first_available_variant.id }}"
                                class="product-variant-id"
                                {% if product.selected_or_first_available_variant.available == false %}
                                disabled
                                {% endif %}
                            >
                            <button
                                id="{{ product_form_id }}-submit"
                                type="submit"
                                name="add"
                                class="quick-add__submit button button--full-width button--secondary"
                                aria-haspopup="dialog"
                                aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                                aria-live="polite"
                                data-sold-out-message="true"
                                {% if product.selected_or_first_available_variant.available == false %}
                                disabled
                                {% endif %}
                                style="{% if block.settings.make_it_selected %}background-color: {{ block.settings.bg_color }}; color: {{ block.settings.color_text }};{% endif %}"
                            >
                                <span>
                                {%- if product.selected_or_first_available_variant.available -%}
                                    Choose {{ block.settings.heading | default: product.title }}
                                {%- else -%}
                                    {{ 'products.product.sold_out' | t }}
                                {%- endif -%}
                                </span>
                                <span class="sold-out-message hidden">
                                {{ 'products.product.sold_out' | t }}
                                </span>
                                {%- render 'loading-spinner' -%}
                            </button>
                        {%- endform -%}
                    </product-form>
                </div>
            {% endif %}
        {% endfor %}
    </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleButtons = document.querySelectorAll('.des_toggle_btn');
        
    
        toggleButtons.forEach(button => {
        button.addEventListener('click', function() {
            const contentId = this.getAttribute('aria-controls');
            const content = document.getElementById(contentId);
            const isExpanded = this.getAttribute('aria-expanded') === 'true';
            const defaultLabel = this.getAttribute('data-default-label') || this.querySelector('.button-label').textContent.trim();
    
            this.setAttribute('aria-expanded', !isExpanded);
            // change the text content and rotate the icon            
            if (!isExpanded) {
                this.querySelector('.button-label').textContent = 'Hide included items';
                this.querySelector('.svg-wrapper').style.transform = 'rotate(180deg)';
            } else {                
                this.querySelector('.button-label').textContent = defaultLabel;
                this.querySelector('.svg-wrapper').style.transform = 'rotate(0deg)';
            }
            content.classList.toggle('active');
        });
        });
    });
</script>

{% schema %}
    {
        "name": "Curated Bundle Blocks",
        "settings": [
            {
                "type": "range",
                "id": "columns_desktop",
                "min": 1,
                "max": 4,
                "step": 1,
                "label": "Product columns",
                "default": 3
            },
            {
                "type": "select",
                "id": "columns_mobile",
                "default": "2",
                "label": "t:sections.featured-collection.settings.columns_mobile.label",
                "options": [
                    {
                        "value": "1",
                        "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label"
                    },
                    {
                        "value": "2",
                        "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label"
                    }
                ]
            },  
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "t:sections.all.colors.label",
                "info": "t:sections.all.colors.has_cards_info",
                "default": "scheme-1"
            },    
            {
                "type": "header",
                "content": "t:sections.all.padding.section_padding_heading"
            },
            {
                "type": "range",
                "id": "padding_top",
                "min": 0,
                "max": 100,
                "step": 4,
                "unit": "px",
                "label": "t:sections.all.padding.padding_top",
                "default": 36
            },
            {
                "type": "range",
                "id": "padding_bottom",
                "min": 0,
                "max": 100,
                "step": 4,
                "unit": "px",
                "label": "t:sections.all.padding.padding_bottom",
                "default": 36
            }
        ],
        "blocks": [
            {
                "type": "curated_product_block",
                "name": "Curated Product Block",
                "settings": [
                    {
                        "type": "product",
                        "id": "product",
                        "label": "Curated Product"
                    },
                    {
                        "type": "checkbox",
                        "id": "make_it_selected",
                        "label": "Make It Selected",
                        "default": false
                    },
                   
                    {
                        "type": "color_scheme",
                        "id": "color_scheme",
                        "label": "Block Color Scheme",
                        "default": "scheme-1"
                    },   
                    {
                        "type": "text",
                        "id": "heading",
                        "label": "Heading"
                    },
                    {
                        "type": "text",
                        "id": "subheading",
                        "label": "Subheading"
                    },
                    {
                        "type": "text",
                        "id": "des_heading_1",
                        "label": "Description Heading 1",
                        "default": "BEST FOR",
                    },
                    {
                        "type": "richtext",
                        "id": "description_1",
                        "label": "Description 1"
                    },
                     {
                        "type": "text",
                        "id": "des_heading_2",
                        "label": "Description Heading 2",
                        "default": "INCLUDES",
                    },
                    {
                        "type": "text",
                        "id": "include_button_label",
                        "label": "Include Button Label",
                        "default": "See included items",
                        "info": "This button will visible only on mobile Screen"
                    },
                    {
                        "type": "richtext",
                        "id": "description_2",
                        "label": "Description 2"
                    },
                    {
                        "type": "text",
                        "id": "badge",
                        "label": "Badge",
                        "placeholder": "Popular"
                    },
                    {
                        "type": "color",
                        "id": "bg_color",
                        "label": "Badge background Color",
                        "default": "#CC858F",
                    },
                    {
                        "type": "color",
                        "id": "color_text",
                        "label": "Badge Text Color",
                        "default": "#fff"
                    }
                    
                    
                ]
            }
        ],
        "presets": [
            {
                "name": "Curated Bundle Blocks"
            }
        ]
    }
{% endschema %}
